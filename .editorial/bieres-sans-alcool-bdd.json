    "auteur": "Dago Beer — zythologue",
    "perimetre": "Bières sans alcool (0.0%) et low-ABV (≤ 3.5%) distribuées en France : brasseries françaises (priorité) + grandes marques internationales très distribuées en France",
    "usage": "Source de vérité éditoriale pour générer les fiches /biere-sans-alcool/[slug] et la page d'index /biere-sans-alcool/. À utiliser avec Claude Code pour produire les fichiers src/content/bieresSansAlcool/*.json",
    "convention": {
      "ID": "slug = identifiant unique (kebab-case) — sert aussi de nom de fichier final et de partie d'URL",
      "champsEditoriaux": "note (1-5) et avisZythologue sont à rédiger par le zythologue avant publication. Champs marqués dans aRediger.",
      "verified": "true = données vérifiées sur source officielle ; false = à valider avant publication",
      "prixMoyen": "Indicatif TTC pour 33cl en grande distribution / cave. À affiner."
    }
  },
  "_schema": {
    "slug": "string (kebab-case, unique)",
    "nom": "string — nom commercial complet",
    "marque": "string — marque visible en rayon",
    "brasserie": "string — brasserie qui produit physiquement (peut différer de la marque)",
    "groupeBrassicole": "string|null — groupe parent (Kronenbourg/Carlsberg, Heineken, AB InBev, Diageo, indépendant)",
    "ville": "string — ville de la brasserie de production",
    "region": "string — région administrative française (ou pays si hors FR)",
    "departement": "string|null — département FR (ex: '74 Haute-Savoie')",
    "paysProduction": "string — pays de brassage réel",
    "style": "string — style de bière (Pale Ale, IPA, Lager, Stout…)",
    "categorieSeo": "enum — 'blonde' | 'brune' | 'blanche' | 'ipa' | 'pale-ale' | 'stout' | 'weissbier' | 'sour' | 'lager' | 'abbaye' | 'aromatisee'",
    "abv": "number — % alcool volumique",
    "ibu": "number|null — amertume (International Bitterness Units)",
    "ebc": "number|null — couleur (European Brewery Convention)",
    "format": "string — ex: '33cl bouteille', '33cl canette', '25cl bouteille'",
    "contenant": "enum — 'bouteille' | 'canette' | 'pression' | 'mixte'",
    "bio": "boolean",
    "sansGluten": "boolean",
    "vegan": "boolean|null",
    "description": "string — 2-3 phrases factuelles sur la bière",
    "profilAromatique": "string — notes aromatiques principales, en mots-clés",
    "prixMoyen": "number|null — prix TTC indicatif en € pour 33cl",
    "note": "number|null — note /5 (éditorial zythologue)",
    "siteOfficielBrasserie": "string|null — URL racine brasserie",
    "urlFicheProduit": "string|null — URL fiche produit officielle ou source faisant foi",
    "urlSaveurBiere": "string|null",
    "urlUnePetiteMousse": "string|null",
    "urlBeerWulf": "string|null",
    "avisZythologue": "string — avis éditorial (à rédiger par le zythologue)",
    "aRediger": "array — liste des champs encore à compléter avant publication",
    "verified": "boolean — true si données factuelles vérifiées sur source officielle",
    "sources": "array — URLs de référence ayant servi à remplir la fiche"
  },
