---
import '@/styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  type?: 'article' | 'website';
}

const {
  title,
  description,
  canonical,
  image = '/og-default.jpg',
  type = 'website',
} = Astro.props;

const siteUrl = 'https://www.dago.beer';
const canonicalUrl = canonical ? canonical : new URL(Astro.url.pathname, siteUrl).href;
const ogImage = image.startsWith('http') ? image : new URL(image, siteUrl).href;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Google Site Verification -->
    <meta name="google-site-verification" content="qG_ao4ETOGlQ3l02tpRy_H9SFrBltr9LXifpkmix6nk" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Dago Beer" />
    <meta property="og:locale" content="fr_FR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Exo:ital,wght@0,300;0,400;0,500;0,700;1,400&display=swap"
      rel="stylesheet"
    />

    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-7YE8JGR1BX"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-7YE8JGR1BX');
    </script>

    <!-- Google AdSense -->
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9075412178223250"
      crossorigin="anonymous"
    ></script>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body class="bg-bg text-muted font-body min-h-screen flex flex-col">
    <!-- Navbar -->
    <header class="bg-white border-b border-gray-200 shadow-sm sticky top-0 z-50">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
        <a href="/" class="font-heading text-2xl font-bold text-amber-brand tracking-wide hover:opacity-90 transition-opacity">
          dago.<span class="text-muted/50 inline-block" style="transform:rotate(180deg);vertical-align:-0.17em;">beer</span>
        </a>
        <ul class="hidden md:flex items-center gap-6 text-sm font-body">
          <li>
            <a href="/biere-sans-alcool" class="text-amber-brand font-semibold hover:opacity-80 transition-opacity">
              Bière Sans Alcool
            </a>
          </li>
          <li>
            <a href="/brasserie-biere-artisanale" class="text-muted/70 hover:text-amber-brand transition-colors">
              Brasseries Artisanales
            </a>
          </li>
          <li>
            <a href="/brassage-amateur" class="text-muted/70 hover:text-amber-brand transition-colors">
              Brassage Amateur
            </a>
          </li>
        </ul>
        <button id="menu-btn" class="md:hidden text-muted/70 hover:text-amber-brand transition-colors" aria-label="Menu" aria-expanded="false">
          <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </nav>
      <!-- Mobile menu panel -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-gray-200 bg-white">
        <ul class="flex flex-col font-body text-base">
          <li>
            <a href="/biere-sans-alcool" class="flex items-center px-6 py-4 text-amber-brand font-semibold border-b border-gray-100 hover:bg-surface transition-colors">
              Bière Sans Alcool
            </a>
          </li>
          <li>
            <a href="/brasserie-biere-artisanale" class="flex items-center px-6 py-4 text-muted/80 border-b border-gray-100 hover:bg-surface hover:text-amber-brand transition-colors">
              Brasseries Artisanales
            </a>
          </li>
          <li>
            <a href="/brassage-amateur" class="flex items-center px-6 py-4 text-muted/80 hover:bg-surface hover:text-amber-brand transition-colors">
              Brassage Amateur
            </a>
          </li>
        </ul>
      </div>
    </header>
    <script is:inline>
      (function () {
        var btn = document.getElementById('menu-btn');
        var menu = document.getElementById('mobile-menu');
        var iconOpen = document.getElementById('icon-open');
        var iconClose = document.getElementById('icon-close');
        btn.addEventListener('click', function () {
          var open = menu.classList.toggle('hidden');
          btn.setAttribute('aria-expanded', String(!open));
          iconOpen.classList.toggle('hidden', !open);
          iconClose.classList.toggle('hidden', open);
        });
      })();
    </script>

    <!-- Main content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-amber-brand border-t border-white/10 mt-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <div class="md:col-span-1">
            <a href="/" class="font-heading text-xl font-bold text-white">dago.beer</a>
            <p class="mt-2 text-sm text-white/70 font-body">
              Le média de référence sur la bière sans alcool et la bière artisanale française.
            </p>
          </div>
          <div>
            <h3 class="font-heading text-sm font-semibold text-white uppercase tracking-wider mb-4">Bière sans alcool</h3>
            <ul class="space-y-2 text-sm font-body text-white/70">
              <li><a href="/biere-sans-alcool" class="hover:text-white transition-colors">Guide complet</a></li>
              <li><a href="/biere-sans-alcool" class="hover:text-white transition-colors">Meilleures bières 0.0</a></li>
              <li><a href="/biere-sans-alcool" class="hover:text-white transition-colors">Bières low-ABV</a></li>
            </ul>
          </div>
          <div>
            <h3 class="font-heading text-sm font-semibold text-white uppercase tracking-wider mb-4">Brasseries</h3>
            <ul class="space-y-2 text-sm font-body text-white/70">
              <li><a href="/brasserie-biere-artisanale" class="hover:text-white transition-colors">Annuaire brasseries</a></li>
              <li><a href="/brasserie-biere-artisanale" class="hover:text-white transition-colors">Brasseries par région</a></li>
              <li><a href="/brassage-amateur" class="hover:text-white transition-colors">Brassage amateur</a></li>
            </ul>
          </div>
          <div>
            <h3 class="font-heading text-sm font-semibold text-white uppercase tracking-wider mb-4">Ressources</h3>
            <ul class="space-y-2 text-sm font-body text-white/70">
              <li><a href="/articles" class="hover:text-white transition-colors">Articles</a></li>
              <li><a href="/brassage-amateur" class="hover:text-white transition-colors">Recettes bière maison</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-8 pt-8 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-4">
          <p class="text-xs text-white/50 font-body">© {new Date().getFullYear()} dago.beer — Tous droits réservés</p>
        </div>
      </div>
    </footer>
  </body>
</html>
