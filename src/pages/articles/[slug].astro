---
import Base from '@/layouts/Base.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import CrossSellBanner from '@/components/CrossSellBanner.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => ({
    params: { slug: article.id.replace(/\.mdx?$/, '') },
    props: { article },
  }));
}

const { article } = Astro.props;
const slug = article.id.replace(/\.mdx?$/, '');
const { titre, date, excerpt, image, tags, sponsorise } = article.data;
const { Content } = await render(article);

const dateFormatee = date.toLocaleDateString('fr-FR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base
  title={`${titre} — Dago Beer`}
  description={excerpt}
  canonical={`https://www.dago.beer/articles/${slug}`}
  image={image}
  type="article"
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <Breadcrumb
      items={[
        { label: 'Articles', href: '/articles' },
        { label: titre },
      ]}
    />

    {sponsorise && (
      <div class="mb-4 text-xs font-body text-muted/40 uppercase tracking-wider">Article sponsorisé</div>
    )}

    <header class="mb-8">
      <div class="flex flex-wrap gap-2 mb-4">
        {tags.map((tag) => (
          <span class="text-xs font-body px-2 py-0.5 rounded-full bg-amber-brand/20 text-amber-brand border border-amber-brand/30">
            {tag}
          </span>
        ))}
      </div>
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-4">{titre}</h1>
      <p class="font-body text-lg text-muted/70 mb-4">{excerpt}</p>
      <time class="font-body text-sm text-muted/40" datetime={date.toISOString()}>
        Publié le {dateFormatee}
      </time>
    </header>

    {image && (
      <div class="rounded-xl overflow-hidden mb-10 aspect-video">
        <img src={image} alt={titre} class="w-full h-full object-cover" />
      </div>
    )}

    <article class="prose prose-invert prose-amber max-w-none font-body prose-headings:font-heading prose-a:text-amber-brand">
      <Content />
    </article>

    <CrossSellBanner />
  </div>
</Base>
