---
import Base from '@/layouts/Base.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles'))
  .filter((a) => a.data.tags.some((t) => ['brassage-amateur', 'recette-biere', 'kit-brassage', 'debutant', 'microbrasseries'].includes(t)))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const recettesAll = await getCollection('recettes');
const nbRecettes = recettesAll.length;
---

<Base
  title="Brassage amateur — Guide complet pour brasser sa bière maison — Dago Beer"
  description="Apprenez à brasser votre propre bière : kits de démarrage, recettes, techniques, conseils de zythologues passionnés. Tout pour se lancer dans le brassage amateur."
  canonical="https://www.dago.beer/brassage-amateur"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <Breadcrumb items={[{ label: 'Brassage amateur' }]} />

    <header class="mb-12 max-w-3xl">
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-4">
        Brassage <span class="text-amber-brand">amateur</span>
      </h1>
      <p class="font-body text-lg text-muted/70">
        Guides pratiques, recettes de bière maison et conseils d'experts pour vous lancer dans l'aventure du brassage artisanal à domicile.
      </p>
    </header>

    <!-- CTA Kit -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-16">
      {[
        { titre: 'Kit débutant', desc: 'Tout le matériel pour brasser votre première bière maison.', icon: '🍺', href: null },
        { titre: 'Recettes', desc: `${nbRecettes}+ recettes clé en main pour tous les styles.`, icon: '📋', href: '/recette-biere' },
        { titre: 'Houblons', desc: 'Base de données de 242 variétés de houblons avec profils aromatiques.', icon: '🌿', href: '/houblons' },
      ].map((item) => (
        <div class={`bg-surface border border-white/10 rounded-xl p-6 text-center${item.href ? ' hover:border-amber-brand/50 transition-colors' : ''}`}>
          {item.href ? (
            <a href={item.href}>
              <div class="text-4xl mb-3">{item.icon}</div>
              <h3 class="font-heading text-lg font-semibold text-white mb-2 hover:text-amber-brand transition-colors">{item.titre}</h3>
            </a>
          ) : (
            <>
              <div class="text-4xl mb-3">{item.icon}</div>
              <h3 class="font-heading text-lg font-semibold text-white mb-2">{item.titre}</h3>
            </>
          )}
          <p class="font-body text-sm text-muted/60">{item.desc}</p>
        </div>
      ))}
    </div>

    {articles.length > 0 && (
      <section>
        <h2 class="font-heading text-2xl font-bold text-white mb-6">Guides et articles</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {articles.map((article) => (
            <ArticleCard
              slug={article.id.replace(/\.mdx?$/, '')}
              titre={article.data.titre}
              date={article.data.date}
              excerpt={article.data.excerpt}
              image={article.data.image}
              tags={article.data.tags}
            />
          ))}
        </div>
      </section>
    )}
  </div>
</Base>
