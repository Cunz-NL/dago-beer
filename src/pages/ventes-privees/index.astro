---
import Base from '@/layouts/Base.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
---

<Base
  title="Ventes privées bières artisanales — Offres exclusives — Dago Beer"
  description="Accédez aux meilleures offres et ventes privées de bières artisanales françaises. Coffrets, packs dégustations et éditions limitées réservés aux membres."
  canonical="https://www.dago.beer/ventes-privees"
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <Breadcrumb items={[{ label: 'Ventes privées' }]} />

    <header class="mb-10">
      <h1 class="font-heading text-4xl font-bold text-white mb-3">
        Ventes <span class="text-amber-brand">privées</span>
      </h1>
      <p class="font-body text-lg text-muted/70">
        Offres exclusives sur les meilleures bières artisanales françaises — coffrets, packs dégustations et éditions limitées.
      </p>
    </header>

    <div class="bg-surface border border-amber-brand/30 rounded-xl p-8 text-center">
      <p class="font-heading text-2xl font-semibold text-white mb-3">Bientôt disponible</p>
      <p class="font-body text-muted/70 mb-6">
        Les ventes privées reviennent prochainement. Inscrivez-vous pour être alerté en priorité.
      </p>
      <a
        href="/liste-d-attente"
        class="inline-block font-body font-semibold px-6 py-3 rounded-lg bg-amber-brand text-bg hover:bg-amber-brand/90 transition-colors"
      >
        Rejoindre la liste d'attente
      </a>
    </div>
  </div>
</Base>
