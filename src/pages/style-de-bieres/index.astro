---
import Base from '@/layouts/Base.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const styles = (await getCollection('bieresStyles')).sort((a, b) =>
  a.data.nom.localeCompare(b.data.nom, 'fr')
);
const familles = await getCollection('bieresFamilles');
const familleMap = Object.fromEntries(familles.map((f) => [f.data.slug, f.data.nom]));
---

<Base
  title="Styles de bières artisanales — Guide complet — Dago Beer"
  description={`Découvrez les ${styles.length} styles de bières artisanales : IPA, Stout, Blonde, Saison, Porter... Caractéristiques, arômes et exemples pour chaque style.`}
  canonical="https://www.dago.beer/style-de-bieres"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <Breadcrumb items={[{ label: 'Styles de bière' }]} />

    <header class="mb-10">
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-3">
        Styles de bières <span class="text-amber-brand">artisanales</span>
      </h1>
      <p class="font-body text-lg text-muted/70">
        Guide complet des {styles.length} styles de bières craft — caractéristiques, profils aromatiques et exemples.
      </p>
    </header>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
      {styles.map((s) => (
        <a
          href={`/style-de-bieres/${s.data.slug}`}
          class="bg-surface border border-white/10 rounded-lg p-4 hover:border-amber-brand/50 hover:bg-amber-brand/5 transition-all group text-center"
        >
          <p class="font-heading text-sm font-semibold text-white group-hover:text-amber-brand transition-colors line-clamp-2">
            {s.data.nom}
          </p>
        </a>
      ))}
    </div>
  </div>
</Base>
