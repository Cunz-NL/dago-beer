---
// URL Webflow : /microbrasserie/[slug] — articles sur l'ouverture de microbrasserie
import Base from '@/layouts/Base.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import CrossSellBanner from '@/components/CrossSellBanner.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles
    .filter((a) => a.data.tags.includes('microbrasseries'))
    .map((a) => ({
      params: { slug: a.id.replace(/\.mdx?$/, '') },
      props: { article: a },
    }));
}

const { article } = Astro.props;
const slug = article.id.replace(/\.mdx?$/, '');
const { titre, date, excerpt, image, tags } = article.data;
const { Content } = await render(article);

const dateFormatee = date.toLocaleDateString('fr-FR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base
  title={`${titre} — Microbrasserie — Dago Beer`}
  description={excerpt}
  canonical={`https://dago.beer/microbrasserie/${slug}`}
  image={image}
  type="article"
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <Breadcrumb
      items={[
        { label: 'Ouvrir une microbrasserie', href: '/ouvrir-une-microbrasserie' },
        { label: titre },
      ]}
    />

    <header class="mb-8">
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-4">{titre}</h1>
      <p class="font-body text-lg text-muted/70 mb-4">{excerpt}</p>
      <time class="font-body text-sm text-muted/40" datetime={date.toISOString()}>
        Publié le {dateFormatee}
      </time>
    </header>

    {image && (
      <div class="rounded-xl overflow-hidden mb-10 aspect-video">
        <img src={image} alt={titre} class="w-full h-full object-cover" />
      </div>
    )}

    <article class="prose prose-invert prose-amber max-w-none font-body prose-headings:font-heading prose-a:text-amber-brand">
      <Content />
    </article>

    <CrossSellBanner />

    <div class="mt-8">
      <a href="/ouvrir-une-microbrasserie" class="font-body text-sm text-muted/50 hover:text-amber-brand transition-colors">
        ← Ouvrir une microbrasserie
      </a>
    </div>
  </div>
</Base>
