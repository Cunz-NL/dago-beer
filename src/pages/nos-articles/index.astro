---
import Base from '@/layouts/Base.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base
  title="Tous nos articles — Bière artisanale & sans alcool — Dago Beer"
  description={`${articles.length} articles sur la bière artisanale, la bière sans alcool, le brassage amateur et la microbrasserie. Guides, sélections et actualités.`}
  canonical="https://www.dago.beer/nos-articles"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <Breadcrumb items={[{ label: 'Articles' }]} />

    <header class="mb-10">
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-3">
        Nos <span class="text-amber-brand">articles</span>
      </h1>
      <p class="font-body text-lg text-muted/70">
        {articles.length} articles sur la bière artisanale, sans alcool, brassage amateur et microbrasserie.
      </p>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {articles.map((article) => (
        <ArticleCard
          slug={article.id.replace(/\.mdx?$/, '')}
          titre={article.data.titre}
          date={article.data.date}
          excerpt={article.data.excerpt}
          image={article.data.image}
          tags={article.data.tags}
        />
      ))}
    </div>
  </div>
</Base>
