---
// URL Webflow : /houblon/[slug] (singulier — à préserver pour le SEO)
import Base from '@/layouts/Base.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const houblons = await getCollection('houblons');
  return houblons.map((h) => ({
    params: { slug: h.data.slug },
    props: { houblon: h },
  }));
}

const { houblon } = Astro.props;
const { nom, description, aaMin, aaMax, baMin, baMax, usage, stabilite, cohumulone, myrcene, caryophyllene, humulene, aromes } = houblon.data;
---

<Base
  title={`Houblon ${nom} — Caractéristiques & usage brassage — Dago Beer`}
  description={description
    ? description.slice(0, 200)
    : `Fiche complète du houblon ${nom} : alpha-acides ${aaMin ?? '?'}–${aaMax ?? '?'}%, usage ${usage ?? 'non précisé'}, profil aromatique et utilisation en brassage artisanal.`}
  canonical={`https://dago.beer/houblon/${houblon.data.slug}`}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <Breadcrumb
      items={[
        { label: 'Brassage amateur', href: '/brassage-amateur' },
        { label: 'Houblons', href: '/liste-des-houblons' },
        { label: nom },
      ]}
    />

    <header class="mb-8 flex items-start gap-4 flex-wrap">
      <div class="flex-1">
        <h1 class="font-heading text-4xl font-bold text-white mb-2">{nom}</h1>
        {usage && (
          <span class="font-body text-sm px-3 py-1 rounded-full bg-amber-brand/20 text-amber-brand border border-amber-brand/30">
            {usage}
          </span>
        )}
      </div>
    </header>

    {description && (
      <div class="bg-surface border border-white/10 rounded-xl p-6 mb-8">
        <p class="font-body text-muted/80 leading-relaxed">{description}</p>
      </div>
    )}

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4 mb-8">
      {[
        { label: 'Alpha (AA)', value: aaMin !== undefined && aaMax !== undefined ? `${aaMin}–${aaMax}%` : null },
        { label: 'Bêta (BA)', value: baMin !== undefined && baMax !== undefined ? `${baMin}–${baMax}%` : null },
        { label: 'Cohumulone', value: cohumulone || null },
        { label: 'Myrcène', value: myrcene || null },
        { label: 'Caryophyllène', value: caryophyllene || null },
        { label: 'Humulène', value: humulene || null },
        { label: 'Stabilité', value: stabilite || null },
      ].filter((s) => s.value !== null).map((stat) => (
        <div class="bg-surface border border-white/10 rounded-lg p-4 text-center">
          <p class="font-body text-xs text-muted/50 uppercase tracking-wider mb-1">{stat.label}</p>
          <p class="font-heading text-lg font-bold text-amber-brand">{stat.value}</p>
        </div>
      ))}
    </div>

    {aromes.length > 0 && (
      <div class="bg-surface border border-white/10 rounded-xl p-6 mb-8">
        <h2 class="font-heading text-lg font-semibold text-white mb-4">Profil aromatique</h2>
        <div class="flex flex-wrap gap-2">
          {aromes.map((arome) => (
            <a
              href={`/houblons-aromes/${arome.replace(/[^a-z0-9-]/gi, '-').toLowerCase()}`}
              class="font-body text-sm px-3 py-1.5 rounded-full bg-white/5 text-muted/70 border border-white/10 hover:border-amber-brand/40 hover:text-amber-brand transition-colors capitalize"
            >
              {arome.replace(/-/g, ' ')}
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="mt-8">
      <a href="/liste-des-houblons" class="font-body text-sm text-muted/50 hover:text-amber-brand transition-colors">
        ← Tous les houblons
      </a>
    </div>
  </div>
</Base>
