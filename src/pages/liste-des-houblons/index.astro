---
import Base from '@/layouts/Base.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const houblons = (await getCollection('houblons')).sort((a, b) =>
  a.data.nom.localeCompare(b.data.nom, 'fr')
);
const usages = [...new Set(houblons.map((h) => h.data.usage).filter(Boolean))];
---

<Base
  title="Liste des houblons — Encyclopédie complète brassage — Dago Beer"
  description={`Liste complète de ${houblons.length} variétés de houblons pour le brassage artisanal. Alpha-acides, profils aromatiques, usage et origine de chaque variété.`}
  canonical="https://dago.beer/liste-des-houblons"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <Breadcrumb items={[{ label: 'Liste des houblons' }]} />

    <header class="mb-8">
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-3">
        Liste des <span class="text-amber-brand">houblons</span>
      </h1>
      <p class="font-body text-lg text-muted/70">
        {houblons.length} variétés référencées — cliquez sur un houblon pour sa fiche complète.
      </p>
      <div class="flex flex-wrap gap-2 mt-4">
        {usages.map((usage) => (
          <span class="font-body text-xs px-3 py-1 rounded-full bg-surface border border-white/10 text-muted/60">
            {usage}
          </span>
        ))}
      </div>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
      {houblons.map((h) => (
        <a
          href={`/houblon/${h.data.slug}`}
          class="bg-surface border border-white/10 rounded-lg p-4 hover:border-amber-brand/50 hover:bg-amber-brand/5 transition-all group"
        >
          <h2 class="font-heading text-sm font-semibold text-white group-hover:text-amber-brand transition-colors mb-1">
            {h.data.nom}
          </h2>
          <div class="flex items-center gap-2 flex-wrap">
            {h.data.aaMin !== undefined && h.data.aaMax !== undefined && (
              <span class="text-xs font-body text-green-400">AA {h.data.aaMin}–{h.data.aaMax}%</span>
            )}
            {h.data.usage && (
              <span class="text-xs font-body text-muted/40">{h.data.usage}</span>
            )}
          </div>
          {h.data.aromes.length > 0 && (
            <p class="font-body text-xs text-muted/30 mt-1 line-clamp-1">
              {h.data.aromes.slice(0, 3).join(', ')}
            </p>
          )}
        </a>
      ))}
    </div>
  </div>
</Base>
