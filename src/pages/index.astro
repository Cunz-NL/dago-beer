---
import Base from '@/layouts/Base.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import BeerCard from '@/components/BeerCard.astro';
import RegionGrid from '@/components/RegionGrid.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const bieres = (await getCollection('bieresSansAlcool'))
  .sort((a, b) => b.data.note - a.data.note)
  .slice(0, 3);

const regions = await getCollection('regions');
const brasseries = await getCollection('brasseries');

const brasseriesParRegion = brasseries.reduce<Record<string, number>>((acc, b) => {
  const r = b.data.region;
  acc[r] = (acc[r] ?? 0) + 1;
  return acc;
}, {});
---

<Base
  title="Dago Beer — Bière sans alcool & brasseries artisanales françaises"
  description="Le média de référence sur la bière sans alcool et low-ABV, plus l'annuaire complet de 1500+ brasseries artisanales françaises."
>
  <!-- Hero -->
  <section class="relative bg-surface border-b border-gray-200 py-20 px-4 text-center overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-amber-brand/5 via-transparent to-transparent pointer-events-none"></div>
    <div class="relative max-w-3xl mx-auto">
      <h1 class="font-heading text-5xl md:text-6xl font-bold text-amber-brand mb-4">
        La bière sans alcool,<br />
        <span class="text-amber-brand/70">prise au sérieux.</span>
      </h1>
      <p class="font-body text-lg text-muted/70 mb-8 max-w-xl mx-auto">
        Sélection experte, avis de zythologue, comparatifs. Plus l'annuaire de 1 500+ brasseries artisanales françaises.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/biere-sans-alcool"
          class="font-body font-semibold px-6 py-3 rounded-lg bg-amber-brand text-white hover:bg-amber-brand/90 transition-colors"
        >
          Découvrir les bières sans alcool
        </a>
        <a
          href="/brasserie-biere-artisanale"
          class="font-body font-semibold px-6 py-3 rounded-lg border border-gray-300 text-muted hover:border-amber-brand/50 hover:text-amber-brand transition-colors"
        >
          Annuaire brasseries →
        </a>
      </div>
    </div>
  </section>

  <!-- Bières sans alcool en vedette -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="font-heading text-3xl font-bold text-amber-brand">
        Bières sans alcool <span class="text-amber-brand/60">à la une</span>
      </h2>
      <a href="/biere-sans-alcool" class="font-body text-sm text-amber-brand hover:opacity-70 transition-opacity">
        Voir tout →
      </a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {bieres.map((biere) => (
        <BeerCard
          slug={biere.data.slug}
          nom={biere.data.nom}
          marque={biere.data.marque}
          style={biere.data.style}
          abv={biere.data.abv}
          note={biere.data.note}
          description={biere.data.description}
          urlSaveurBiere={biere.data.urlSaveurBiere}
          urlUnePetiteMousse={biere.data.urlUnePetiteMousse}
          urlBeerWulf={biere.data.urlBeerWulf}
        />
      ))}
    </div>
  </section>

  <!-- Articles récents -->
  <section class="bg-surface border-y border-gray-200 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <h2 class="font-heading text-3xl font-bold text-amber-brand">Articles récents</h2>
        <a href="/articles" class="font-body text-sm text-amber-brand hover:opacity-70 transition-opacity">
          Tous les articles →
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {articles.map((article) => (
          <ArticleCard
            slug={article.id.replace(/\.mdx?$/, '')}
            titre={article.data.titre}
            date={article.data.date}
            excerpt={article.data.excerpt}
            image={article.data.image}
            tags={article.data.tags}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Régions -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="font-heading text-3xl font-bold text-amber-brand mb-2">
      Brasseries par région
    </h2>
    <p class="font-body text-muted/60 mb-8">1 500+ brasseries artisanales référencées dans toute la France</p>
    <RegionGrid regions={regions} brasseriesParRegion={brasseriesParRegion} />
  </section>
</Base>
