---
export interface Props {
  slug: string;
  nom: string;
  marque: string;
  style: string;
  abv: number;
  note: number;
  urlSaveurBiere?: string;
  urlUnePetiteMousse?: string;
  urlBeerWulf?: string;
  description?: string;
}

const { slug, nom, marque, style, abv, note, urlSaveurBiere, urlUnePetiteMousse, urlBeerWulf, description } = Astro.props;

const isZero = abv === 0.0;
const abvLabel = isZero ? '0.0%' : `${abv.toFixed(1)}%`;
const abvClass = isZero
  ? 'bg-green-600/20 text-green-400 border-green-600/30'
  : 'bg-orange-600/20 text-orange-400 border-orange-600/30';

const affiliateLinks = [
  { label: 'Saveur Bière', url: urlSaveurBiere },
  { label: 'Une Petite Mousse', url: urlUnePetiteMousse },
  { label: 'Beer Wulf', url: urlBeerWulf },
].filter((l): l is { label: string; url: string } => Boolean(l.url));
---

<article class="bg-surface rounded-lg border border-white/10 hover:border-amber-brand/50 transition-colors group p-5">
  <div class="flex items-start justify-between gap-3 mb-3">
    <div class="flex-1 min-w-0">
      <a href={`/biere-sans-alcool/${slug}`}>
        <h3 class="font-heading text-lg font-semibold text-white group-hover:text-amber-brand transition-colors line-clamp-1">
          {nom}
        </h3>
      </a>
      <p class="font-body text-sm text-muted/60">{marque} · {style}</p>
    </div>
    <span class={`shrink-0 text-xs font-body font-semibold px-2 py-1 rounded-full border ${abvClass}`}>
      {abvLabel}
    </span>
  </div>

  <!-- Étoiles -->
  <div class="flex items-center gap-1 mb-3" aria-label={`Note : ${note}/5`}>
    {Array.from({ length: 5 }).map((_, i) => (
      <svg
        class={`w-4 h-4 ${i < note ? 'text-amber-brand' : 'text-white/20'}`}
        fill="currentColor"
        viewBox="0 0 20 20"
        aria-hidden="true"
      >
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}
    <span class="font-body text-xs text-muted/50 ml-1">{note}/5</span>
  </div>

  {description && (
    <p class="font-body text-sm text-muted/70 line-clamp-2 mb-4">{description}</p>
  )}

  {affiliateLinks.length > 0 && (
    <div class="flex flex-wrap gap-2 mt-auto">
      {affiliateLinks.map((link) => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer sponsored"
          class="text-xs font-body px-3 py-1.5 rounded border border-amber-brand/40 text-amber-brand hover:bg-amber-brand hover:text-bg transition-colors"
        >
          {link.label} →
        </a>
      ))}
    </div>
  )}
</article>
